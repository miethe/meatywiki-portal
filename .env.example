MEATYWIKI_PORTAL_API_URL=http://127.0.0.1:8765
MEATYWIKI_PORTAL_TOKEN=changeme-local-dev-token

# Set to 1 to bypass login/token validation (pairs with backend PORTAL_DISABLE_AUTH=1).
# Server-side: skips backend token validation in route handlers and validate.ts.
PORTAL_DISABLE_AUTH=0

# Set to 1 to bypass login flow on the client (shows auto-login banner).
# Must match PORTAL_DISABLE_AUTH=1 on the server side.
NEXT_PUBLIC_PORTAL_DISABLE_AUTH=0

# ---------------------------------------------------------------------------
# PWA (experimental) — P4-01
# ---------------------------------------------------------------------------

# Set to 1 to enable PWA features: service worker registration and manifest.
# Mirrors backend PORTAL_ENABLE_PWA=1.
# Off by default — no install prompts or SW registration unless opted in.
# Requirements: HTTPS in production, or localhost / 127.0.0.1 for local dev.
# iOS Safari <16.4 limitation: manifest-based installation not supported;
# the app still works in Safari but cannot be installed as a PWA on older iOS.
# See README.md §"PWA (experimental)" for browser support matrix.
NEXT_PUBLIC_PORTAL_ENABLE_PWA=0
